{
  "name": "chatgpt-ctrl-enter-sender",
  "version": "2.3.1",
  "private": true,
  "description": "Browser extension that assigns Ctrl+Enter to send messages in ChatGPT and other AI chat sites, so Enter inserts a line break",
  "main": "background.js",
  "scripts": {
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --test tools/ctrl-enter-handler.test.js",
    "test:integration": "playwright test",
    "test:loading": "playwright test extension-loading",
    "test:live": "playwright test --config=playwright.live.config.js",
    "test:sites": "playwright test --config=playwright.live.config.js site-accessibility",
    "test:behavior": "playwright test --config=playwright.live.config.js ctrl-enter-behavior",
    "test:public": "playwright test --config=playwright.live.config.js --grep 'Public Sites'",
    "login": "node tests/login-helper.js",
    "login:all": "node tests/login-helper.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masachika-kamada/ChatGPT-Ctrl-Enter-Sender.git"
  },
  "keywords": [],
  "author": "Masachika Kamada",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/masachika-kamada/ChatGPT-Ctrl-Enter-Sender/issues"
  },
  "homepage": "https://github.com/masachika-kamada/ChatGPT-Ctrl-Enter-Sender#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
